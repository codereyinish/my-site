---
// Animated network-flow mockup: node cards connected by a flowing rail with a
// packet that travels out (cyan) and returns (green). Used on the homepage and
// the projects page so both stay in sync.
interface FlowNode {
	label: string;
	icon: string;
	active?: boolean;
}
interface Props {
	title: string;
	caption: string;
	nodes: FlowNode[];
	/** Chrome-less variant that fills its parent — used as a blog-card thumbnail. */
	compact?: boolean;
}
const { title, caption, nodes, compact = false } = Astro.props;

const ICONS: Record<string, string> = {
	laptop: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="11" rx="2"/><path d="M2 20h20"/></svg>`,
	shield: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v5c0 4-3 7.2-7 8-4-.8-7-4-7-8V6l7-3z"/><path d="M9 12l2 2 4-4"/></svg>`,
	server: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="7" rx="1.5"/><rect x="4" y="13" width="16" height="7" rx="1.5"/><path d="M7.5 7.5h.01M7.5 16.5h.01"/></svg>`,
	globe: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3c2.7 2.6 2.7 15.4 0 18M12 3c-2.7 2.6-2.7 15.4 0 18"/></svg>`,
	phone: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="7" y="3" width="10" height="18" rx="2.5"/><path d="M11 18h2"/></svg>`,
	cloud: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M7 18a4 4 0 01-.5-7.97 5 5 0 019.7-1.4A3.5 3.5 0 0116.5 18H7z"/></svg>`,
	mic: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="3" width="6" height="10" rx="3"/><path d="M6 11a6 6 0 0012 0M12 17v3M9 20h6"/></svg>`,
	wave: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12h2l2-5 3 13 3-17 3 15 2-6h3"/></svg>`,
	chip: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="6" y="6" width="12" height="12" rx="2"/><path d="M9 3v3M15 3v3M9 18v3M15 18v3M3 9h3M3 15h3M18 9h3M18 15h3"/></svg>`,
	doc: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M7 3h7l4 4v14H7z"/><path d="M14 3v4h4M9.5 12h5M9.5 16h5"/></svg>`,
	chat: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M20 15a2 2 0 01-2 2H8l-4 4V5a2 2 0 012-2h12a2 2 0 012 2z"/></svg>`,
	brain: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M9.5 4A2.5 2.5 0 007 6.5 3 3 0 006 12a3 3 0 003 3v1a2 2 0 004 0V6.5A2.5 2.5 0 009.5 4zM14.5 4A2.5 2.5 0 0117 6.5 3 3 0 0118 12a3 3 0 01-3 3"/></svg>`,
};
---

<div class={compact ? 'flow-demo flow-compact' : 'project-demo flow-demo'}>
	{!compact && (
		<div class="demo-chrome">
			<span class="chrome-dot" style="background:#ff5f56"></span>
			<span class="chrome-dot" style="background:#febc2e"></span>
			<span class="chrome-dot" style="background:#28c840"></span>
			<span class="chrome-url mono">{title}</span>
		</div>
	)}
	<div class="flow-screen">
		<div class="flow">
			<div class="flow-rail"><span class="flow-packet"></span></div>
			<div class="flow-nodes">
				{nodes.map((n) => (
					<div class={`flow-node${n.active ? ' active' : ''}`}>
						<span class="flow-icon" set:html={ICONS[n.icon] ?? ICONS.globe} />
						<span class="flow-label mono">{n.label}</span>
					</div>
				))}
			</div>
		</div>
		<div class="flow-caption mono">{caption}</div>
	</div>
</div>

<style>
	.flow-screen {
		padding: 26px 18px 22px;
		min-height: 200px;
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 22px;
	}

	/* Compact variant: fills a blog-card image slot, no chrome */
	.flow-compact {
		position: absolute;
		inset: 0;
		display: flex;
		background: var(--surface2);
	}
	.flow-compact .flow-screen {
		flex: 1;
		min-height: 0;
		padding: 18px 16px;
		gap: 16px;
	}
	.flow-compact .flow-icon { width: 40px; height: 40px; border-radius: 11px; }
	.flow-compact .flow-icon :global(svg) { width: 19px; height: 19px; }
	.flow-compact .flow-rail { top: 20px; }
	.flow-compact .flow-label { font-size: 9.5px; }

	.flow { position: relative; }

	/* Connector rail sits behind the node icons, centered on them */
	.flow-rail {
		position: absolute;
		top: 24px;
		left: 12.5%;
		right: 12.5%;
		height: 2px;
		border-radius: 2px;
		background:
			repeating-linear-gradient(90deg, rgba(56,189,248,0.55) 0 6px, transparent 6px 12px);
		background-size: 12px 2px;
		animation: flow-dash 0.9s linear infinite;
		z-index: 0;
	}
	.flow-rail::before {
		content: "";
		position: absolute;
		inset: -1px 0;
		background: linear-gradient(90deg, transparent, rgba(56,189,248,0.12) 50%, transparent);
		border-radius: 2px;
	}
	@keyframes flow-dash { to { background-position: 12px 0; } }

	.flow-packet {
		position: absolute;
		top: 50%;
		left: 0;
		width: 10px; height: 10px;
		margin: -5px 0 0 -5px;
		border-radius: 50%;
		background: #7dd3fc;
		box-shadow: 0 0 6px 2px rgba(56,189,248,0.9), -14px 0 12px -4px rgba(56,189,248,0.55);
		animation: flow-packet 3.6s ease-in-out infinite;
	}
	@keyframes flow-packet {
		0%   { left: 0%;   opacity: 0; background: #7dd3fc; box-shadow: 0 0 6px 2px rgba(56,189,248,0.9), -14px 0 12px -4px rgba(56,189,248,0.55); }
		8%   { opacity: 1; }
		44%  { left: 100%; opacity: 1; background: #7dd3fc; box-shadow: 0 0 6px 2px rgba(56,189,248,0.9), -14px 0 12px -4px rgba(56,189,248,0.55); }
		50%  { left: 100%; opacity: 1; background: #86efac; box-shadow: 0 0 6px 2px rgba(34,197,94,0.9), 14px 0 12px -4px rgba(34,197,94,0.55); }
		92%  { left: 0%;   opacity: 1; background: #86efac; box-shadow: 0 0 6px 2px rgba(34,197,94,0.9), 14px 0 12px -4px rgba(34,197,94,0.55); }
		100% { left: 0%;   opacity: 0; }
	}

	.flow-nodes { position: relative; z-index: 1; display: flex; justify-content: space-between; }
	.flow-node { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 10px; }
	.flow-icon {
		width: 48px; height: 48px;
		display: flex; align-items: center; justify-content: center;
		border-radius: 13px;
		border: 1px solid var(--border);
		background: var(--surface2);
		color: var(--text-muted);
		transition: color 0.3s, border-color 0.3s, box-shadow 0.3s;
	}
	.flow-icon :global(svg) { width: 22px; height: 22px; }
	.flow-node.active .flow-icon {
		color: #38bdf8;
		border-color: rgba(56,189,248,0.55);
		box-shadow: 0 0 0 1px rgba(56,189,248,0.25), 0 0 18px rgba(56,189,248,0.35);
		animation: flow-glow 2.2s ease-in-out infinite;
	}
	@keyframes flow-glow {
		0%, 100% { box-shadow: 0 0 0 1px rgba(56,189,248,0.25), 0 0 14px rgba(56,189,248,0.3); }
		50%      { box-shadow: 0 0 0 1px rgba(56,189,248,0.4), 0 0 24px rgba(56,189,248,0.5); }
	}
	.flow-label { font-size: 10.5px; letter-spacing: 0.2px; color: var(--text-muted); }
	.flow-node.active .flow-label { color: #38bdf8; }

	.flow-caption { text-align: center; color: #22c55e; font-size: 11px; letter-spacing: 0.3px; }

	@media (max-width: 480px) {
		.flow-icon { width: 40px; height: 40px; }
		.flow-label { font-size: 9.5px; }
	}
</style>
