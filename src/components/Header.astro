---
import HeaderLink from './HeaderLink.astro';
---

<header id="site-header">
	<div class="container">
		<nav>
			<a href="/" class="logo" aria-label="Manish Bista">
				<svg class="logo-svg" width="48" height="30" viewBox="0 0 48 30" fill="none" xmlns="http://www.w3.org/2000/svg">
					<!-- M -->
					<path d="M2 28L2 2L11 14L20 2L20 28"
						stroke="currentColor" stroke-width="2.2"
						stroke-linecap="round" stroke-linejoin="round"/>
					<!-- B vertical -->
					<line x1="26" y1="2" x2="26" y2="28"
						stroke="currentColor" stroke-width="2.2"
						stroke-linecap="round"/>
					<!-- B top bump -->
					<path d="M26 2C38 2 38 14 26 14"
						stroke="currentColor" stroke-width="2.2"
						stroke-linecap="round" fill="none"/>
					<!-- B bottom bump (wider) -->
					<path d="M26 14C40 14 40 28 26 28"
						stroke="currentColor" stroke-width="2.2"
						stroke-linecap="round" fill="none"/>
					<!-- Blue accent dot -->
					<circle cx="44.5" cy="26" r="2.8" fill="#3b82f6"/>
				</svg>
			</a>
			<div class="nav-links">
				<HeaderLink href="/about">About</HeaderLink>
				<HeaderLink href="/projects">Projects</HeaderLink>
				<HeaderLink href="/blog">Writing</HeaderLink>
				<HeaderLink href="/resume">Resume</HeaderLink>
			</div>
			<div class="nav-right">
			<a href="/contact" class="nav-cta">
				<svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
				Book a Call
			</a>
			<a href="https://mbista.beehiiv.com/subscribe" target="_blank" rel="noopener" class="nav-subscribe">Subscribe</a>
				<button id="theme-toggle" class="theme-toggle" type="button" aria-label="Toggle light and dark theme">
					<svg class="icon-sun" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="4.5"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
					<svg class="icon-moon" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/></svg>
				</button>
		</div>
		</nav>
	</div>
</header>

<style>
	header {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 100;
		background: var(--header-bg);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
		border-bottom: 1px solid var(--border);
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		height: 60px;
	}
	.logo {
		text-decoration: none;
		transition: opacity 0.2s;
		display: flex;
		align-items: center;
	}
	.logo:hover { opacity: 0.75; }
	.logo-svg {
		color: var(--text);
		display: block;
	}
	.nav-links {
		display: flex;
		align-items: center;
		gap: 4px;
	}
	.nav-right {
		display: flex;
		align-items: center;
		gap: 8px;
	}
	.nav-subscribe {
		display: inline-flex;
		align-items: center;
		padding: 8px 16px;
		border-radius: 8px;
		background: var(--blue);
		font-size: 13px;
		font-weight: 500;
		color: #fff;
		text-decoration: none;
		transition: opacity 0.2s;
	}
	.nav-subscribe:hover { opacity: 0.85; }
	.theme-toggle {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 34px;
		height: 34px;
		border-radius: 8px;
		border: 1px solid var(--border-light);
		background: transparent;
		color: var(--text-secondary);
		cursor: pointer;
		flex-shrink: 0;
		transition: color 0.2s, border-color 0.2s, background 0.2s;
	}
	.theme-toggle:hover { color: var(--text); border-color: var(--text-secondary); }
	.theme-toggle svg { display: block; }
	.icon-moon { display: none; }
	html[data-theme="light"] .icon-sun { display: none; }
	html[data-theme="light"] .icon-moon { display: block; }
	.nav-cta {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		padding: 8px 16px;
		border-radius: 8px;
		border: 1px solid var(--border-light);
		font-size: 13px;
		font-weight: 500;
		color: var(--text-secondary);
		text-decoration: none;
		transition: all 0.2s ease;
	}
	.nav-cta:hover {
		border-color: var(--text-secondary);
		color: var(--text);
	}
	@media (max-width: 768px) {
		.nav-cta, .nav-subscribe { display: none; }
		.nav-links { gap: 0; }
	}
	@media (max-width: 480px) {
		.nav-links a { font-size: 12px; padding: 5px 8px; }
	}
</style>

<script>
	const root = document.documentElement;
	document.getElementById('theme-toggle')?.addEventListener('click', () => {
		const next = root.dataset.theme === 'light' ? 'dark' : 'light';
		root.dataset.theme = next;
		try { localStorage.setItem('theme', next); } catch (e) {}
	});
</script>

