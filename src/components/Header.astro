---
import HeaderLink from './HeaderLink.astro';
---

<header id="site-header">
	<div class="container">
		<nav>
			<a href="/" class="logo" aria-label="Manish Bista">
				<svg class="logo-svg" width="48" height="30" viewBox="0 0 48 30" fill="none" xmlns="http://www.w3.org/2000/svg">
					<!-- M -->
					<path d="M2 28L2 2L11 14L20 2L20 28"
						stroke="currentColor" stroke-width="2.2"
						stroke-linecap="round" stroke-linejoin="round"/>
					<!-- B vertical -->
					<line x1="26" y1="2" x2="26" y2="28"
						stroke="currentColor" stroke-width="2.2"
						stroke-linecap="round"/>
					<!-- B top bump -->
					<path d="M26 2C38 2 38 14 26 14"
						stroke="currentColor" stroke-width="2.2"
						stroke-linecap="round" fill="none"/>
					<!-- B bottom bump (wider) -->
					<path d="M26 14C40 14 40 28 26 28"
						stroke="currentColor" stroke-width="2.2"
						stroke-linecap="round" fill="none"/>
					<!-- Blue accent dot -->
					<circle cx="44.5" cy="26" r="2.8" fill="#3b82f6"/>
				</svg>
			</a>
			<div class="nav-links">
				<HeaderLink href="/about">About</HeaderLink>
				<HeaderLink href="/projects">Projects</HeaderLink>
				<HeaderLink href="/blog">Writing</HeaderLink>
				<HeaderLink href="/resume">Resume</HeaderLink>
			</div>
			<a href="/contact" class="nav-cta">
				<svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
				Book a Call
			</a>
		</nav>
	</div>
</header>

<style>
	header {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 100;
		background: rgba(0, 0, 0, 0.7);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
		border-bottom: 1px solid var(--border);
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		height: 60px;
	}
	.logo {
		text-decoration: none;
		transition: opacity 0.2s;
		display: flex;
		align-items: center;
	}
	.logo:hover { opacity: 0.75; }
	.logo-svg {
		color: var(--text);
		display: block;
	}
	.nav-links {
		display: flex;
		align-items: center;
		gap: 4px;
	}
	.nav-cta {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		padding: 8px 16px;
		border-radius: 8px;
		border: 1px solid var(--border-light);
		font-size: 13px;
		font-weight: 500;
		color: var(--text-secondary);
		text-decoration: none;
		transition: all 0.2s ease;
	}
	.nav-cta:hover {
		border-color: var(--text-secondary);
		color: var(--text);
	}
	@media (max-width: 768px) {
		.nav-cta { display: none; }
		.nav-links { gap: 0; }
	}
	@media (max-width: 480px) {
		.nav-links a:nth-child(n+3) { display: none; }
	}
</style>
