---
import HeaderLink from './HeaderLink.astro';
---

<header id="site-header">
	<div class="container">
		<nav>
			<a href="/" class="logo">
				<span class="logo-text">Inish<span class="logo-dot">.</span></span>
			</a>
			<div class="nav-links">
				<HeaderLink href="/about">About</HeaderLink>
				<HeaderLink href="/projects">Projects</HeaderLink>
				<HeaderLink href="/blog">Writing</HeaderLink>
				<HeaderLink href="/resume">Resume</HeaderLink>
			</div>
			<a href="mailto:inishbista@gmail.com" class="nav-cta">
				Get in touch
				<svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
			</a>
		</nav>
	</div>
</header>

<style>
	header {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 100;
		background: rgba(0, 0, 0, 0.7);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
		border-bottom: 1px solid var(--border);
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		height: 60px;
	}
	.logo {
		text-decoration: none;
		transition: opacity 0.2s;
	}
	.logo:hover { opacity: 0.7; }
	.logo-text {
		font-family: var(--font-sans);
		font-size: 1.2rem;
		font-weight: 700;
		letter-spacing: -0.5px;
		color: var(--text);
	}
	.logo-dot { color: var(--blue); }
	.nav-links {
		display: flex;
		align-items: center;
		gap: 4px;
	}
	.nav-cta {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		padding: 8px 16px;
		border-radius: 8px;
		border: 1px solid var(--border-light);
		font-size: 13px;
		font-weight: 500;
		color: var(--text-secondary);
		text-decoration: none;
		transition: all 0.2s ease;
	}
	.nav-cta:hover {
		border-color: var(--text-secondary);
		color: var(--text);
	}
	@media (max-width: 768px) {
		.nav-cta { display: none; }
		.nav-links { gap: 0; }
	}
	@media (max-width: 480px) {
		.nav-links a:nth-child(n+3) { display: none; }
	}
</style>
