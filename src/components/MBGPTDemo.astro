---
// MBGPT chat-stages mockup (Generic → RAG → Fine-tuned). Animates when its
// ancestor .project-row is hovered. Used on the homepage and the projects page.
---

<div class="project-demo">
	<div class="demo-chrome">
		<span class="chrome-dot" style="background:#ff5f56"></span>
		<span class="chrome-dot" style="background:#febc2e"></span>
		<span class="chrome-dot" style="background:#28c840"></span>
		<span class="chrome-url mono">mbgpt · comment assistant</span>
	</div>
	<div class="demo-screen mbgpt-screen">
		<div class="mb-comment">
			<div class="mb-avatar mb-avatar-user"></div>
			<div class="mb-bubble mb-bubble-user">
				This tutorial really helped me understand overfitting! 🔥
			</div>
		</div>
		<div class="mb-stages">
			<div class="mb-stage mb-stage-1">
				<span class="mb-label mono">01 · Generic</span>
				<p>Thank you for your kind comment!</p>
			</div>
			<div class="mb-stage mb-stage-2">
				<span class="mb-label mono">02 · RAG</span>
				<p>Glad the dropout explanation clicked for you!</p>
			</div>
			<div class="mb-stage mb-stage-3 mb-best">
				<span class="mb-label mono">03 · Fine-tuned ✦</span>
				<p>haha yeah overfitting got me too for the longest time 😅 stay tuned next week</p>
			</div>
		</div>
	</div>
</div>

<style>
	.demo-screen { padding: 16px; min-height: 220px; }
	.mbgpt-screen { display: flex; flex-direction: column; gap: 10px; }
	.mb-comment { display: flex; align-items: flex-start; gap: 8px; }
	.mb-avatar { width: 28px; height: 28px; border-radius: 50%; background: var(--border-light); flex-shrink: 0; }
	.mb-bubble { font-size: 12px; color: var(--text-secondary); background: var(--surface2); border-radius: 8px; padding: 8px 12px; line-height: 1.5; }
	.mb-stages { display: flex; flex-direction: column; gap: 6px; }
	.mb-stage {
		padding: 8px 12px;
		border-radius: 8px;
		border: 1px solid var(--border);
		opacity: 0;
		transform: translateX(-8px);
		transition: opacity 0.4s, transform 0.4s;
	}
	:global(.project-row:hover) .mb-stage-1 { opacity:1; transform:none; transition-delay: 0.1s; }
	:global(.project-row:hover) .mb-stage-2 { opacity:1; transform:none; transition-delay: 0.3s; }
	:global(.project-row:hover) .mb-stage-3 { opacity:1; transform:none; transition-delay: 0.5s; }
	.mb-best { border-color: rgba(16,163,127,0.35); background: rgba(16,163,127,0.06); }
	.mb-label { font-size: 9px; letter-spacing: 1px; color: var(--text-muted); display: block; margin-bottom: 3px; }
	.mb-stage p { font-size: 12px; color: var(--text-secondary); margin: 0; line-height: 1.4; }
	.mb-best p { color: var(--text); }
</style>
