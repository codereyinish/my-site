---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { TECH_ICONS } from '../lib/techIcons';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);

const langBadges  = ['Python', 'TypeScript', 'JavaScript', 'SQL', 'HTML', 'CSS'];
const frameBadges = ['FastAPI', 'React', 'Next.js', 'Docker', 'PostgreSQL', 'Vercel', 'Git', 'GitHub'];
const aimlBadges  = ['OpenAI API', 'Whisper', 'RAG', 'Fine-tuning', 'Jupyter', 'Astro', 'Linux', 'WebSockets'];

---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />

		<!-- ═══ HERO ══════════════════════════════════ -->
		<section class="hero">
			<div class="container">
				<div class="hero-inner">
					<div class="hero-left animate-fadeInDown">
						<p class="hero-script serif">Manish Bista</p>
						<h1 class="hero-heading">
							CS student building<br/>
							AI-powered software.
						</h1>
						<p class="hero-sub">
							I build tools I wish existed — from live lecture transcription
							to AI comment assistants. Based in New York, originally from Nepal&nbsp;🇳🇵
						</p>
						<div class="hero-actions">
							<a href="/contact" class="btn btn-primary">Contact me</a>
							<a href="/projects" class="btn hero-ghost">View projects</a>
						</div>
					</div>
					<div class="hero-right animate-fadeInDown delay-2">
						<div class="hero-portrait-wrap">
							<img
								src="/manish-portrait.jpg"
								alt="Manish Bista"
								class="hero-portrait"
							/>
							<div class="sq sq-1"></div>
							<div class="sq sq-2"></div>
							<div class="sq sq-3"></div>
							<div class="sq sq-4"></div>
						</div>
					</div>
				</div>
			</div>
			<div class="scroll-indicator" aria-hidden="true">
				<div class="scroll-line">
					<div class="scroll-dot"></div>
				</div>
				<span class="scroll-label mono">scroll</span>
			</div>
		</section>

		<!-- ═══ TECH STACK (canvas net + scrolling badges) ═ -->
		<section class="tech-section">
			<canvas id="tech-net" aria-hidden="true"></canvas>
			<div class="tech-content">
				<div class="container">
					<div class="tech-card">
						<div class="tech-card-header">
							<p class="section-eyebrow mono">Tech Stack</p>
							<h2 class="tech-card-h2">Tools I ship <span class="serif">production code</span> with</h2>
						</div>

						<!-- Languages -->
						<div class="tech-row-group">
							<span class="row-label mono">Languages</span>
							<div class="marquee-row">
								<div class="marquee-track" style="--dur:32s">
									{[...langBadges, ...langBadges].map(name => (
										<span class="tech-badge">
											<Fragment set:html={TECH_ICONS[name] ?? ''} />
											{name}
										</span>
									))}
								</div>
							</div>
						</div>

						<!-- Frameworks & Tools -->
						<div class="tech-row-group">
							<span class="row-label mono">Frameworks &amp; Tools</span>
							<div class="marquee-row marquee-reverse">
								<div class="marquee-track" style="--dur:40s">
									{[...frameBadges, ...frameBadges].map(name => (
										<span class="tech-badge">
											<Fragment set:html={TECH_ICONS[name] ?? ''} />
											{name}
										</span>
									))}
								</div>
							</div>
						</div>

						<!-- AI / ML -->
						<div class="tech-row-group">
							<span class="row-label mono">AI &amp; ML</span>
							<div class="marquee-row">
								<div class="marquee-track" style="--dur:36s">
									{[...aimlBadges, ...aimlBadges].map(name => (
										<span class="tech-badge">
											<Fragment set:html={TECH_ICONS[name] ?? ''} />
											{name}
										</span>
									))}
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- ═══ PROJECTS ══════════════════════════════ -->
		<section class="projects-section">
			<div class="container">
				<div class="section-header">
					<div>
						<p class="section-eyebrow mono">Case Studies</p>
						<h2>Selected <span class="serif">Work</span></h2>
					</div>
					<a href="/projects" class="section-link">
						All projects
						<svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
					</a>
				</div>

				<div class="projects-list">

					<!-- 01 ClassRec -->
					<article class="project-row">
						<div class="project-num mono">01</div>
						<div class="project-content">
							<div class="project-meta">
								<span class="project-year mono">Q4 2024</span>
								<span class="badge">Active</span>
							</div>
							<h3 class="project-title">ClassRec</h3>
							<p class="project-desc">
								A live lecture transcription SaaS — captures, transcribes, and organizes
								classroom audio in real time so students can focus on learning instead of
								frantic note-taking.
							</p>
							<div class="project-tech-row">
								<span class="tech-tag" style="--tc:#3b82f6"><Fragment set:html={TECH_ICONS['Python']} />Python</span>
								<span class="tech-tag" style="--tc:#06b6d4"><Fragment set:html={TECH_ICONS['FastAPI']} />FastAPI</span>
								<span class="tech-tag" style="--tc:#8b5cf6"><Fragment set:html={TECH_ICONS['Whisper']} />Whisper</span>
								<span class="tech-tag" style="--tc:#61dafb"><Fragment set:html={TECH_ICONS['React']} />React</span>
								<span class="tech-tag" style="--tc:#22c55e"><Fragment set:html={TECH_ICONS['WebSockets']} />WebSockets</span>
							</div>
						</div>
						<!-- Animated browser mockup -->
						<div class="project-demo">
							<div class="demo-chrome">
								<span class="chrome-dot" style="background:#ff5f56"></span>
								<span class="chrome-dot" style="background:#febc2e"></span>
								<span class="chrome-dot" style="background:#28c840"></span>
								<span class="chrome-url mono">classrec.app</span>
							</div>
							<div class="demo-screen classrec-screen">
								<div class="cr-header">
									<div class="cr-title">Live Transcript</div>
									<span class="cr-live"><span class="live-dot"></span>REC</span>
								</div>
								<div class="cr-lines">
									<div class="cr-line cr-line-1">Professor: "Today we're covering neural networks..."</div>
									<div class="cr-line cr-line-2">The architecture consists of layers...</div>
									<div class="cr-line cr-line-3">Each neuron receives inputs weighted by...</div>
									<div class="cr-line cr-line-4 cr-typing">Backpropagation adjusts these weights<span class="cursor">|</span></div>
								</div>
								<div class="cr-bar">
									<div class="cr-waveform">
										{Array.from({length: 20}).map((_, i) => (
											<span class="wave-bar" style={`animation-delay:${i * 0.08}s`}></span>
										))}
									</div>
									<span class="cr-timer mono">12:34</span>
								</div>
							</div>
						</div>
					</article>

					<div class="section-divider"></div>

					<!-- 02 MBGPT -->
					<article class="project-row">
						<div class="project-num mono">02</div>
						<div class="project-content">
							<div class="project-meta">
								<span class="project-year mono">Q3 2024</span>
								<span class="badge">Shipped</span>
							</div>
							<h3 class="project-title">MBGPT</h3>
							<p class="project-desc">
								An AI YouTube comment assistant that replies in a creator's own voice —
								context-aware, human-toned, never generic. Baseline → RAG → fine-tuned.
							</p>
							<div class="project-tech-row">
								<span class="tech-tag" style="--tc:#3b82f6"><Fragment set:html={TECH_ICONS['Python']} />Python</span>
								<span class="tech-tag" style="--tc:#10a37f"><Fragment set:html={TECH_ICONS['OpenAI API']} />OpenAI API</span>
								<span class="tech-tag" style="--tc:#f59e0b"><Fragment set:html={TECH_ICONS['RAG']} />RAG</span>
								<span class="tech-tag" style="--tc:#8b5cf6"><Fragment set:html={TECH_ICONS['Fine-tuning']} />Fine-tuning</span>
							</div>
							<div class="project-links">
								<a href="https://github.com/codereyinish/MBGPT" target="_blank" rel="noopener" class="project-link">
									GitHub <svg width="11" height="11" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
								</a>
							</div>
						</div>
						<!-- Animated chat mockup -->
						<div class="project-demo">
							<div class="demo-chrome">
								<span class="chrome-dot" style="background:#ff5f56"></span>
								<span class="chrome-dot" style="background:#febc2e"></span>
								<span class="chrome-dot" style="background:#28c840"></span>
								<span class="chrome-url mono">mbgpt · comment assistant</span>
							</div>
							<div class="demo-screen mbgpt-screen">
								<div class="mb-comment">
									<div class="mb-avatar mb-avatar-user"></div>
									<div class="mb-bubble mb-bubble-user">
										This tutorial really helped me understand overfitting! 🔥
									</div>
								</div>
								<div class="mb-stages">
									<div class="mb-stage mb-stage-1">
										<span class="mb-label mono">01 · Generic</span>
										<p>Thank you for your kind comment!</p>
									</div>
									<div class="mb-stage mb-stage-2">
										<span class="mb-label mono">02 · RAG</span>
										<p>Glad the dropout explanation clicked for you!</p>
									</div>
									<div class="mb-stage mb-stage-3 mb-best">
										<span class="mb-label mono">03 · Fine-tuned ✦</span>
										<p>haha yeah overfitting got me too for the longest time 😅 stay tuned next week</p>
									</div>
								</div>
							</div>
						</div>
					</article>

				</div>
			</div>
		</section>

		<!-- ═══ TESTIMONIALS ══════════════════════════ -->
	<section class="testimonials-section">
		<div class="container">
			<div class="testimonials-header">
				<div>
					<p class="section-eyebrow mono">Testimonials</p>
					<h2>What people say <span class="serif">about me</span></h2>
				</div>
				<div class="t-nav">
					<button class="t-arrow" id="t-prev" aria-label="Previous">
						<svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M15 18l-6-6 6-6"/></svg>
					</button>
					<button class="t-arrow" id="t-next" aria-label="Next">
						<svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 18l6-6-6-6"/></svg>
					</button>
				</div>
			</div>
			<div class="t-track-wrap"><div class="testimonials-track" id="t-track">

				<div class="tcard">
					<p class="tcard-quote">"Quiet, but always thinking two steps ahead."</p>
					<p class="tcard-body">Manish stays silent most of the time — but when he speaks, it's worth listening. He thinks more than he talks, and that shows in everything he builds. Our conversations about product and startups are always some of the most insightful I have. Genuinely one of the most thoughtful people I know.</p>
					<div class="tcard-person">
						<div class="tcard-avatar">SS</div>
						<div>
							<p class="tcard-name">Sohum Sah</p>
							<p class="tcard-role">Peer &amp; Collaborator</p>
						</div>
					</div>
				</div>

				<div class="tcard">
					<p class="tcard-quote">"Codes every single day — no matter what."</p>
					<p class="tcard-body">What sets Manish apart is his consistency. He codes every day without exception. Hardworking and competitive in the best way — he doesn't settle. Watching him improve week over week is motivating. If you're building something and need someone who truly shows up, he's that person.</p>
					<div class="tcard-person">
						<div class="tcard-avatar">AT</div>
						<div>
							<p class="tcard-name">Abin Thapa</p>
							<p class="tcard-role">Friend &amp; Fellow Builder</p>
						</div>
					</div>
				</div>

				<div class="tcard">
					<p class="tcard-quote">"Always eager to learn — it's rare to see."</p>
					<p class="tcard-body">Manish has an unusual hunger for learning. He picks up new things fast and applies them even faster. Always great to talk to about entrepreneurship and new tech. The kind of developer who helps you think through a problem, not just fix it. Glad I got to work alongside him.</p>
					<div class="tcard-person">
						<div class="tcard-avatar">RZ</div>
						<div>
							<p class="tcard-name">Richard Zams</p>
							<p class="tcard-role">Mentor &amp; Advisor</p>
						</div>
					</div>
				</div>

				<div class="tcard">
					<p class="tcard-quote">"A self-learner who came further than anyone expected."</p>
					<p class="tcard-body">Manish went from thinking he wasn't a computer person to being one of the most dedicated coders I know. He taught himself everything — no shortcuts. He admires Elon Musk's relentless drive, and you can feel that energy in how he approaches every project. A remarkable transformation.</p>
					<div class="tcard-person">
						<div class="tcard-avatar">SK</div>
						<div>
							<p class="tcard-name">Sam Keir</p>
							<p class="tcard-role">WiseTel</p>
						</div>
					</div>
				</div>

				<div class="tcard">
					<p class="tcard-quote">"One of the most driven people I've worked with."</p>
					<p class="tcard-body">Manish has a rare combination of technical depth and genuine curiosity. He doesn't just build things — he thinks about why they matter. Every conversation leaves you with something new to think about. He's the kind of person who makes the people around him better.</p>
					<div class="tcard-person">
						<div class="tcard-avatar">XN</div>
						<div>
							<p class="tcard-name">Xi Nai</p>
							<p class="tcard-role">Colleague &amp; Collaborator</p>
						</div>
					</div>
				</div>

			</div></div>
		</div>
	</section>

	<!-- ═══ BLOG ═══════════════════════════════════ -->
		{posts.length > 0 && (
			<section class="blog-section">
				<div class="container">
					<div class="section-header">
						<div>
							<p class="section-eyebrow mono">Writing</p>
							<h2>Recent <span class="serif">Articles</span></h2>
						</div>
						<a href="/blog" class="section-link">
							All posts <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
						</a>
					</div>
					<div class="blog-grid">
						{posts.map((post, i) => {
							const accents = ['#3b82f6','#06b6d4','#8b5cf6'];
							const accent = accents[i % accents.length];
							return (
								<a href={`/blog/${post.id}/`} class="blog-card" style={`--accent:${accent}`}>
									<div class="blog-card-img-wrap">
										<div class="blog-card-img" style={`background-image:url('${post.data.heroImage ?? `https://picsum.photos/seed/${post.id}-sketch/800/500`}')`}></div>
										<div class="blog-card-sketch"></div>
										<div class="blog-card-accent"></div>
									</div>
									<div class="blog-card-body">
										<span class="blog-card-date mono"><FormattedDate date={post.data.pubDate} /></span>
										<h3 class="blog-card-title">{post.data.title}</h3>
										{post.data.description && <p class="blog-card-desc">{post.data.description}</p>}
									</div>
								</a>
							);
						})}
					</div>
				</div>
			</section>
		)}

		<!-- ═══ CONTACT CTA ("Let's talk" card) ════════ -->
		<section class="contact-section">
			<div class="container">
				<div class="contact-bg-text" aria-hidden="true">LET'S MAKE IT HAPPEN</div>
				<div class="contact-card">
					<div class="contact-card-handle"></div>
					<div class="contact-card-top">
						<div>
							<h2 class="serif contact-heading">Let's talk</h2>
							<p class="mono contact-sub">OPEN TO PROJECTS &amp; COLLABORATIONS</p>
						</div>
					</div>
					<div class="contact-stripe"></div>
					<div class="contact-options">
						<a href="mailto:manishbista@gmail.com" class="contact-opt contact-opt-wide">
							<div>
								<p class="contact-opt-title">Send me a message</p>
								<p class="mono contact-opt-note">I reply within a day</p>
							</div>
							<svg class="contact-arrow" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
							<div class="contact-deco contact-deco-mail">
								<svg width="48" height="48" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24" opacity="0.2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
							</div>
						</a>
						<a href="/contact" class="contact-opt">
							<div>
								<p class="contact-opt-title">Schedule a call</p>
								<p class="mono contact-opt-note">30 min · video or phone</p>
							</div>
							<div class="contact-deco contact-deco-cal">
								<svg width="48" height="48" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24" opacity="0.2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
							</div>
						</a>
					</div>
					<div class="contact-socials">
						<a href="https://linkedin.com/in/manishbista" target="_blank" rel="noopener" aria-label="LinkedIn">
							<svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
						</a>
						<a href="https://github.com/codereyinish" target="_blank" rel="noopener" aria-label="GitHub">
							<svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.64-1.335-5.64-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
						</a>
					</div>
				</div>
			</div>
		</section>

		<Footer />

		<!-- Scroll progress line -->
		<div class="scroll-progress-track" aria-hidden="true">
			<div class="scroll-progress-fill" id="scroll-progress"></div>
		</div>
	</body>
</html>

<style>
/* ── Hero ──────────────────────────────────── */
.hero { position:relative; min-height:100svh; display:flex; align-items:center; padding-top:80px; overflow:hidden; }
.hero-inner { display:grid; grid-template-columns:1fr 1fr; gap:40px; align-items:center; padding:80px 0; }
.hero-script { font-size:1.4rem; font-weight:400; color:var(--text-secondary); margin-bottom:20px; letter-spacing:0; font-style:italic; }
.hero-heading { font-family:var(--font-mono); font-size:clamp(2rem,4vw,3.2rem); font-weight:700; letter-spacing:-1px; line-height:1.15; margin-bottom:24px; color:var(--text); }
.hero-sub { font-size:1rem; color:var(--text-secondary); line-height:1.75; max-width:460px; margin-bottom:36px; }
.hero-actions { display:flex; gap:12px; flex-wrap:wrap; }
.hero-ghost { display:inline-flex; align-items:center; gap:8px; padding:10px 20px; border-radius:8px; font-family:var(--font-sans); font-size:14px; font-weight:500; color:var(--text-secondary); background:transparent; border:none; cursor:pointer; transition:color 0.2s; text-decoration:none; }
.hero-ghost:hover { color:var(--text); }
.stat-num { font-family:var(--font-sans);font-size:1.4rem;font-weight:700;color:var(--text);line-height:1; }
.stat-label { font-family:var(--font-mono);font-size:10px;color:var(--text-muted);letter-spacing:.5px;text-transform:uppercase; }
.stat-divider { width:1px;height:36px;background:var(--border); }
