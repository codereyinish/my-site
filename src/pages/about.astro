---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { TECH_ICONS } from '../lib/techIcons';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="About — Manish Bista" description="CS student at St. Joseph's College NY, originally from Nepal." />
	</head>
	<body>
		<Header />
		<main class="page-main">
			<div class="container">

				<!-- Top intro -->
				<div class="about-top animate-fadeInDown">
					<div class="about-intro">
						<p class="eyebrow mono">About</p>
						<h1>
							I'm Manish,<br/>
							a <span class="serif">builder</span> from Nepal<span style="color:var(--blue)">.</span>
						</h1>
						<p class="about-lead">
							CS student at St. Joseph's College NY, graduating May 2026.
							I build AI-powered software and write about what I learn along the way.
						</p>
					</div>
					<div class="about-photo-wrap">
						<div class="about-photo" style="background-image:url('/manish-portrait.jpg')"></div>
					</div>
				</div>

				<div class="section-divider"></div>

				<!-- Content grid -->
				<div class="about-grid animate-fadeInUp delay-2">
					<div class="about-main">
						<section class="about-section">
							<h2>What I do</h2>
							<p>
								I write code for things I wish existed. Right now that's
								<a href="/projects">ClassRec</a> — a live lecture transcription tool built so
								students can actually listen during class instead of racing to copy every word.
							</p>
							<p>
								Before that, <a href="/projects#mbgpt">MBGPT</a> — an AI comment assistant that
								learns a creator's voice using RAG and fine-tuning on their real comment history.
								These are both personal itch-scratches that became real projects.
							</p>
							<p>
								I'm interested in the intersection of AI and everyday utility — software that
								works quietly in the background and makes people more capable without demanding
								attention.
							</p>
						</section>

						<section class="about-section">
							<h2>Background</h2>
							<p>
								I grew up in Nepal and came to New York for university. That distance gave me a
								specific perspective on technology — not as something assumed, but as something
								built intentionally and toward a purpose.
							</p>
							<p>
								Outside of code, I read a lot. I think about language, communication, and how
								ideas spread. This blog is where I work through things I'm learning — about
								software, building, and the rest of it.
							</p>
						</section>
					</div>

					<aside class="about-sidebar">
						<div class="sidebar-card">
							<h3 class="card-title mono">Quick facts</h3>
							<ul class="fact-list">
								<li>
									<span class="fact-label">School</span>
									<span class="fact-val">St. Joseph's College NY</span>
								</li>
								<li>
									<span class="fact-label">Graduating</span>
									<span class="fact-val">May 2026</span>
								</li>
								<li>
									<span class="fact-label">Based in</span>
									<span class="fact-val">New York, NY</span>
								</li>
								<li>
									<span class="fact-label">From</span>
									<span class="fact-val">Nepal 🇳🇵</span>
								</li>
								<li>
									<span class="fact-label">Status</span>
									<span class="fact-val" style="color:var(--cyan)">Open to work</span>
								</li>
							</ul>
						</div>

						<div class="sidebar-card">
							<h3 class="card-title mono">Tech I use</h3>
							<div class="tech-list">
								<span class="tech-item"><Fragment set:html={TECH_ICONS['Python']}/>Python</span>
								<span class="tech-item"><Fragment set:html={TECH_ICONS['FastAPI']}/>FastAPI</span>
								<span class="tech-item"><Fragment set:html={TECH_ICONS['React']}/>React</span>
								<span class="tech-item"><Fragment set:html={TECH_ICONS['TypeScript']}/>TypeScript</span>
								<span class="tech-item"><Fragment set:html={TECH_ICONS['OpenAI API']}/>OpenAI API</span>
								<span class="tech-item"><Fragment set:html={TECH_ICONS['Whisper']}/>Whisper</span>
								<span class="tech-item"><Fragment set:html={TECH_ICONS['SQL']}/>SQL</span>
								<span class="tech-item"><Fragment set:html={TECH_ICONS['Docker']}/>Docker</span>
							</div>
						</div>

						<div class="sidebar-card contact-card">
							<h3 class="card-title mono">Get in touch</h3>
							<div class="contact-list">
								<a href="mailto:manishbista@gmail.com" class="contact-item">
									<span class="contact-label">Email</span>
									<svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
								</a>
								<a href="https://linkedin.com/in/manishbista" target="_blank" rel="noopener" class="contact-item">
									<span class="contact-label">LinkedIn</span>
									<svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
								</a>
								<a href="https://github.com/codereyinish" target="_blank" rel="noopener" class="contact-item">
									<span class="contact-label">GitHub</span>
									<svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
								</a>
							</div>
						</div>
					</aside>
				</div>

			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	.page-main { padding-top: 100px; position: relative; z-index: 10; }
	.eyebrow { font-size: 11px; letter-spacing: 2.5px; text-transform: uppercase; color: var(--text-muted); margin-bottom: 12px; }

	/* Top */
	.about-top {
		display: grid;
		grid-template-columns: 1fr 340px;
		gap: 64px;
		align-items: start;
		padding: 48px 0 56px;
	}
	h1 { font-size: clamp(2.5rem, 5vw, 4rem); font-weight: 800; letter-spacing: -2px; margin-bottom: 24px; line-height: 1.05; }
	.about-lead { font-size: 1.1rem; color: var(--text-secondary); line-height: 1.75; max-width: 520px; margin: 0; }
	.about-photo {
		width: 100%;
		aspect-ratio: 6/7;
		border-radius: 20px;
		background-size: cover;
		background-position: top center;
		background-color: var(--surface);
	}

	.section-divider { margin-bottom: 64px; }

	/* Content grid */
	.about-grid {
		display: grid;
		grid-template-columns: 1fr 320px;
		gap: 64px;
		align-items: start;
		padding-bottom: 80px;
	}
	.about-section { margin-bottom: 48px; }
	.about-section:last-child { margin-bottom: 0; }
	.about-section h2 {
		font-size: 1.3rem;
		font-weight: 700;
		letter-spacing: -0.3px;
		margin-bottom: 16px;
		color: var(--text);
	}
	.about-section p {
		font-size: 1rem;
		color: rgba(255,255,255,0.7);
		line-height: 1.85;
		margin-bottom: 1em;
	}
	.about-section a { color: var(--blue); border-bottom: 1px solid rgba(59,130,246,0.3); transition: border-color 0.2s; }
	.about-section a:hover { border-color: var(--blue); opacity: 0.85; }

	/* Sidebar */
	.about-sidebar { display: flex; flex-direction: column; gap: 16px; }
	.sidebar-card {
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: 14px;
		padding: 20px;
	}
	.card-title {
		font-size: 10px;
		letter-spacing: 2px;
		text-transform: uppercase;
		color: var(--text-muted);
		margin-bottom: 16px;
		font-weight: 400;
	}
	.fact-list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 0; }
	.fact-list li {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 10px 0;
		border-bottom: 1px solid var(--border);
		font-size: 13px;
	}
	.fact-list li:last-child { border-bottom: none; }
	.fact-label { color: var(--text-muted); font-family: var(--font-mono); font-size: 11px; }
	.fact-val { color: var(--text-secondary); }
	.tech-list { display: flex; flex-wrap: wrap; gap: 6px; }
	.tech-item {
		display: inline-flex;
		align-items: center;
		gap: 5px;
		font-family: var(--font-mono);
		font-size: 11px;
		padding: 3px 10px;
		border: 1px solid var(--border);
		border-radius: 4px;
		color: var(--text-muted);
	}
	.tech-item svg { width: 14px; height: 14px; flex-shrink: 0; display: block; }
	.contact-list { display: flex; flex-direction: column; gap: 0; }
	.contact-item {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 10px 0;
		border-bottom: 1px solid var(--border);
		font-size: 14px;
		color: var(--text-secondary);
		transition: color 0.2s;
	}
	.contact-item:last-child { border-bottom: none; }
	.contact-item:hover { color: var(--text); }

	@media (max-width: 900px) {
		.about-top { grid-template-columns: 1fr; gap: 32px; }
		.about-photo-wrap { display: none; }
		.about-grid { grid-template-columns: 1fr; gap: 40px; }
		.about-sidebar { flex-direction: row; flex-wrap: wrap; }
		.sidebar-card { flex: 1; min-width: 240px; }
	}
	@media (max-width: 580px) {
		.page-main { padding-top: 80px; }
		.about-top { padding: 32px 0 40px; }
	}
</style>
