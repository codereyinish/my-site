---
import type { CollectionEntry } from 'astro:content';
import type { MarkdownHeading } from 'astro';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'] & {
	headings?: MarkdownHeading[];
	readTime?: string;
};

const { title, description, pubDate, updatedDate, heroImage, tags, headings = [], readTime } = Astro.props;
const tocHeadings = headings.filter(h => h.depth <= 3);
const imgSeed = title.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
const coverImg = heroImage ?? `https://picsum.photos/seed/${imgSeed}/1600/700`;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} image={coverImg} />
	</head>
	<body>
		<Header />

		<article class="post-article">
			<!-- Hero cover -->
			<div class="post-cover" style={`background-image:url('${coverImg}')`}>
				<div class="cover-overlay"></div>
				<div class="container">
					<div class="cover-content animate-fadeInDown">
						<a href="/blog" class="back-crumb mono">← Writing</a>
						{tags && tags.length > 0 && (
							<div class="cover-tags">
								{tags.map(t => <span class="cover-tag">{t}</span>)}
							</div>
						)}
						<h1 class="post-title">{title}</h1>
						{description && <p class="post-desc">{description}</p>}
						<div class="post-meta mono">
							<span><FormattedDate date={pubDate} /></span>
							{readTime && <span class="meta-sep">·</span>}
							{readTime && <span>{readTime}</span>}
							{updatedDate && (
								<span class="updated-note">Updated: <FormattedDate date={updatedDate} /></span>
							)}
						</div>
					</div>
				</div>
			</div>

			<!-- Prose + TOC -->
			<div class="container">
				<div class="content-layout animate-fadeInUp">
					<div class="prose-wrap">
						<div class="prose">
							<slot />
						</div>
					<div class="post-footer">
						<div class="post-footer-line"></div>
						{tags && tags.length > 0 && (
							<div class="post-footer-tags">
								<span class="tags-label mono">Tags</span>
								<div class="tags-list">
									{tags.map(t => (
										<a href={`/blog?tag=${encodeURIComponent(t)}`} class="footer-tag">{t}</a>
									))}
								</div>
							</div>
						)}
						<div class="post-footer-nav">
							<a href="/blog" class="back-link">
								<svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
								Back to all posts
							</a>
						</div>
					</div>
				</div>

				<!-- TOC sidebar -->
				{tocHeadings.length > 0 && (
					<aside class="toc-sidebar">
						<div class="toc-inner">
							<p class="toc-label mono">On this page</p>
							<nav class="toc-nav">
								{tocHeadings.map(h => (
									<a
										href={`#${h.slug}`}
										class={`toc-link toc-h${h.depth}`}
										data-heading={h.slug}
									>{h.text}</a>
								))}
							</nav>
						</div>
					</aside>
				)}

				</div>
			</div>
		</article>

		<Footer />
	</body>
</html>

<style>
	/* Cover */
	.post-cover {
		position: relative;
		min-height: 520px;
		display: flex;
		align-items: flex-end;
		background-size: cover;
		background-position: center;
		background-color: var(--surface);
		/* Gradient fallback when no image */
		background-image: linear-gradient(135deg, #0a0a0a 0%, #111827 50%, #0a0a0a 100%);
		padding-top: 80px;
	}
	.cover-overlay {
		position: absolute;
		inset: 0;
		background: linear-gradient(
			to bottom,
			rgba(0,0,0,0.55) 0%,
			rgba(0,0,0,0.75) 60%,
			rgba(0,0,0,0.97) 100%
		);
	}
	.cover-content {
		position: relative;
		z-index: 2;
		padding: 64px 0 60px;
		max-width: 680px;
	}
	.back-crumb {
		display: inline-block;
		font-size: 11px;
		letter-spacing: 1.5px;
		text-transform: uppercase;
		color: rgba(255,255,255,0.45);
		margin-bottom: 16px;
		transition: color 0.2s;
	}
	.back-crumb:hover { color: rgba(255,255,255,0.7); }
	.cover-tags {
		display: flex;
		gap: 6px;
		flex-wrap: wrap;
		margin-bottom: 14px;
	}
	.cover-tag {
		font-family: var(--font-mono);
		font-size: 10px;
		letter-spacing: 1px;
		text-transform: uppercase;
		padding: 3px 10px;
		border: 1px solid rgba(255,255,255,0.2);
		border-radius: 4px;
		color: rgba(255,255,255,0.5);
	}
	.post-title {
		font-size: clamp(2rem, 5vw, 3.5rem);
		font-weight: 800;
		letter-spacing: -1.5px;
		line-height: 1.1;
		color: #fff;
		margin-bottom: 16px;
	}
	.post-desc {
		font-size: 1.1rem;
		color: rgba(255,255,255,0.6);
		max-width: 560px;
		line-height: 1.65;
		margin-bottom: 20px;
	}
	.post-meta {
		display: flex;
		gap: 20px;
		font-size: 11px;
		letter-spacing: 1px;
		color: rgba(255,255,255,0.4);
		text-transform: uppercase;
	}
	.updated-note { color: rgba(255,255,255,0.3); }

	/* Content layout — prose + TOC side by side */
	.content-layout {
		display: flex;
		gap: 64px;
		align-items: flex-start;
		padding: 72px 0 64px;
	}

	/* Prose */
	.prose-wrap {
		flex: 1;
		min-width: 0;
	}
	.prose {
		font-family: 'Georgia', 'Charter', 'Cambria', serif;
		font-size: 1.18rem;
		line-height: 1.95;
		color: var(--text-secondary);
	}
	.prose :global(h1) {
		font-size: 2rem;
		font-weight: 800;
		letter-spacing: -0.5px;
		color: var(--text);
		margin: 3rem 0 1rem;
	}
	.prose :global(h2) {
		font-size: 1.55rem;
		font-weight: 700;
		letter-spacing: -0.4px;
		color: var(--text);
		margin: 3rem 0 0.85rem;
		padding-bottom: 0.5rem;
		border-bottom: 1px solid var(--border);
	}
	.prose :global(h3) {
		font-size: 1.2rem;
		font-weight: 600;
		color: var(--text);
		margin: 2.25rem 0 0.6rem;
	}
	.prose :global(p) { margin-bottom: 1.75em; }
	.prose :global(a) {
		color: var(--blue);
		border-bottom: 1px solid rgba(59,130,246,0.3);
		transition: border-color 0.2s;
	}
	.prose :global(a:hover) { border-color: var(--blue); opacity: 0.85; }
	.prose :global(ul), .prose :global(ol) { padding-left: 1.75rem; margin-bottom: 1.75em; }
	.prose :global(li) { margin-bottom: 0.5em; line-height: 1.75; }
	.prose :global(blockquote) {
		border-left: 3px solid var(--blue);
		padding: 1rem 1.5rem;
		margin: 2.5rem 0;
		color: var(--text-muted);
		font-style: italic;
		font-size: 1.05em;
		background: var(--surface);
		border-radius: 0 8px 8px 0;
	}
	/* Images */
	.prose :global(img) {
		width: 100%;
		border-radius: 12px;
		margin: 2rem 0;
		border: 1px solid var(--border);
		display: block;
	}
	/* Video / iframe */
	.prose :global(iframe) {
		width: 100%;
		aspect-ratio: 16/9;
		border-radius: 12px;
		border: 1px solid var(--border);
		margin: 2rem 0;
		display: block;
	}
	.prose :global(video) {
		width: 100%;
		border-radius: 12px;
		margin: 2rem 0;
		border: 1px solid var(--border);
		display: block;
	}
	/* Inline code */
	.prose :global(code) {
		font-family: var(--font-mono);
		font-size: 0.85em;
		background: rgba(6,182,212,0.08);
		border: 1px solid rgba(6,182,212,0.2);
		padding: 2px 7px;
		border-radius: 4px;
		color: var(--cyan);
	}
	/* Code blocks — Shiki wraps in <pre><code> */
	.prose :global(pre) {
		border-radius: 12px;
		padding: 1.5rem 1.75rem;
		overflow-x: auto;
		margin: 2rem 0;
		border: 1px solid var(--border);
		font-size: 0.9rem;
		line-height: 1.65;
	}
	.prose :global(pre code) {
		background: none;
		border: none;
		padding: 0;
		color: inherit;
		font-size: inherit;
	}
	.prose :global(hr) { margin: 3.5rem 0; border-color: var(--border); }
	.prose :global(table) {
		width: 100%;
		border-collapse: collapse;
		margin: 2rem 0;
		font-size: 0.95em;
	}
	.prose :global(th), .prose :global(td) {
		padding: 10px 16px;
		border: 1px solid var(--border);
		text-align: left;
	}
	.prose :global(th) { background: var(--surface2); color: var(--text); font-weight: 600; }

	/* Footer nav */
	.post-footer { margin-top: 3rem; }
	.post-footer-line { border-top: 1px solid var(--border); margin-bottom: 24px; }
	.post-footer-tags {
		display: flex;
		align-items: center;
		gap: 12px;
		margin-bottom: 24px;
		flex-wrap: wrap;
	}
	.tags-label {
		font-size: 11px;
		letter-spacing: 1.5px;
		text-transform: uppercase;
		color: var(--text-muted);
	}
	.tags-list { display: flex; gap: 8px; flex-wrap: wrap; }
	.footer-tag {
		font-family: var(--font-mono);
		font-size: 11px;
		letter-spacing: 0.5px;
		text-transform: uppercase;
		padding: 4px 12px;
		border: 1px solid var(--border);
		border-radius: 100px;
		color: var(--text-secondary);
		transition: border-color 0.2s, color 0.2s;
	}
	.footer-tag:hover { border-color: var(--border-light); color: var(--text); }
	.post-footer-nav { display: flex; justify-content: space-between; align-items: center; }
	.back-link {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		font-size: 14px;
		font-weight: 500;
		color: var(--text-secondary);
		transition: color 0.2s;
	}
	.back-link:hover { color: var(--text); }

	/* TOC sidebar */
	.toc-sidebar {
		width: 200px;
		flex-shrink: 0;
	}
	.toc-inner {
		position: sticky;
		top: 88px;
	}
	.toc-label {
		font-size: 10px;
		letter-spacing: 2px;
		text-transform: uppercase;
		color: var(--text-muted);
		margin-bottom: 12px;
	}
	.toc-nav {
		display: flex;
		flex-direction: column;
		gap: 2px;
	}
	.toc-link {
		font-size: 12.5px;
		line-height: 1.5;
		color: var(--text-muted);
		padding: 4px 0 4px 10px;
		border-left: 1px solid var(--border);
		transition: color 0.15s, border-color 0.15s;
		text-decoration: none;
		display: block;
	}
	.toc-link:hover { color: var(--text-secondary); }
	.toc-link.active {
		color: var(--text);
		border-left-color: var(--blue);
	}
	.toc-h2 { padding-left: 10px; }
	.toc-h3 { padding-left: 22px; font-size: 12px; }

	@media (max-width: 1100px) {
		.toc-sidebar { display: none; }
	}
	@media (max-width: 720px) {
		.post-cover { min-height: 360px; }
		.cover-content { padding: 40px 0 40px; }
		.content-layout { padding: 40px 0 32px; }
	}
</style>

<script>
// Highlight the active TOC heading as you scroll
const links = document.querySelectorAll<HTMLAnchorElement>('.toc-link');
if (links.length) {
	const headingEls = Array.from(links).map(l =>
		document.getElementById(l.dataset.heading ?? '')
	).filter(Boolean) as HTMLElement[];

	const observer = new IntersectionObserver(entries => {
		entries.forEach(entry => {
			if (entry.isIntersecting) {
				links.forEach(l => l.classList.remove('active'));
				const active = document.querySelector<HTMLAnchorElement>(
					`.toc-link[data-heading="${entry.target.id}"]`
				);
				active?.classList.add('active');
			}
		});
	}, { rootMargin: '-10% 0px -80% 0px' });

	headingEls.forEach(el => observer.observe(el));
}
</script>
