---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, tags } = Astro.props;
const imgSeed = title.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
const coverImg = heroImage ?? `https://picsum.photos/seed/${imgSeed}/1600/700`;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Header />

		<article class="post-article">
			<!-- Hero cover -->
			<div class="post-cover" style={`background-image:url('${coverImg}')`}>
				<div class="cover-overlay"></div>
				<div class="container">
					<div class="cover-content animate-fadeInDown">
						<a href="/blog" class="back-crumb mono">← Writing</a>
						{tags && tags.length > 0 && (
							<div class="cover-tags">
								{tags.map(t => <span class="cover-tag">{t}</span>)}
							</div>
						)}
						<h1 class="post-title">{title}</h1>
						{description && <p class="post-desc">{description}</p>}
						<div class="post-meta mono">
							<span><FormattedDate date={pubDate} /></span>
							{updatedDate && (
								<span class="updated-note">Updated: <FormattedDate date={updatedDate} /></span>
							)}
						</div>
					</div>
				</div>
			</div>

			<!-- Prose -->
			<div class="container">
				<div class="prose-wrap animate-fadeInUp">
					<div class="prose">
						<slot />
					</div>
					<div class="post-footer">
						<div class="post-footer-line"></div>
						<div class="post-footer-nav">
							<a href="/blog" class="back-link">
								<svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
								Back to all posts
							</a>
						</div>
					</div>
				</div>
			</div>
		</article>

		<Footer />
	</body>
</html>

<style>
	/* Cover */
	.post-cover {
		position: relative;
		min-height: 520px;
		display: flex;
		align-items: flex-end;
		background-size: cover;
		background-position: center;
		background-color: var(--surface);
		/* Gradient fallback when no image */
		background-image: linear-gradient(135deg, #0a0a0a 0%, #111827 50%, #0a0a0a 100%);
		padding-top: 80px;
	}
	.cover-overlay {
		position: absolute;
		inset: 0;
		background: linear-gradient(
			to bottom,
			rgba(0,0,0,0.2) 0%,
			rgba(0,0,0,0.6) 60%,
			rgba(0,0,0,0.95) 100%
		);
	}
	.cover-content {
		position: relative;
		z-index: 2;
		padding: 64px 0 60px;
		max-width: 680px;
	}
	.back-crumb {
		display: inline-block;
		font-size: 11px;
		letter-spacing: 1.5px;
		text-transform: uppercase;
		color: rgba(255,255,255,0.45);
		margin-bottom: 16px;
		transition: color 0.2s;
	}
	.back-crumb:hover { color: rgba(255,255,255,0.7); }
	.cover-tags {
		display: flex;
		gap: 6px;
		flex-wrap: wrap;
		margin-bottom: 14px;
	}
	.cover-tag {
		font-family: var(--font-mono);
		font-size: 10px;
		letter-spacing: 1px;
		text-transform: uppercase;
		padding: 3px 10px;
		border: 1px solid rgba(255,255,255,0.2);
		border-radius: 4px;
		color: rgba(255,255,255,0.5);
	}
	.post-title {
		font-size: clamp(2rem, 5vw, 3.5rem);
		font-weight: 800;
		letter-spacing: -1.5px;
		line-height: 1.1;
		color: #fff;
		margin-bottom: 16px;
	}
	.post-desc {
		font-size: 1.1rem;
		color: rgba(255,255,255,0.6);
		max-width: 560px;
		line-height: 1.65;
		margin-bottom: 20px;
	}
	.post-meta {
		display: flex;
		gap: 20px;
		font-size: 11px;
		letter-spacing: 1px;
		color: rgba(255,255,255,0.4);
		text-transform: uppercase;
	}
	.updated-note { color: rgba(255,255,255,0.3); }

	/* Prose */
	.prose-wrap {
		max-width: 680px;
		margin: 0 auto;
		padding: 72px 0 64px;
	}
	.prose {
		font-size: 1.13rem;
		line-height: 1.9;
		color: rgba(255,255,255,0.78);
	}
	.prose :global(h1) {
		font-size: 2rem;
		font-weight: 800;
		letter-spacing: -0.5px;
		color: var(--text);
		margin: 3rem 0 1rem;
	}
	.prose :global(h2) {
		font-size: 1.55rem;
		font-weight: 700;
		letter-spacing: -0.4px;
		color: var(--text);
		margin: 3rem 0 0.85rem;
		padding-bottom: 0.5rem;
		border-bottom: 1px solid var(--border);
	}
	.prose :global(h3) {
		font-size: 1.2rem;
		font-weight: 600;
		color: var(--text);
		margin: 2.25rem 0 0.6rem;
	}
	.prose :global(p) { margin-bottom: 1.75em; }
	.prose :global(a) {
		color: var(--blue);
		border-bottom: 1px solid rgba(59,130,246,0.3);
		transition: border-color 0.2s;
	}
	.prose :global(a:hover) { border-color: var(--blue); opacity: 0.85; }
	.prose :global(ul), .prose :global(ol) { padding-left: 1.75rem; margin-bottom: 1.75em; }
	.prose :global(li) { margin-bottom: 0.5em; line-height: 1.75; }
	.prose :global(blockquote) {
		border-left: 3px solid var(--blue);
		padding: 1rem 1.5rem;
		margin: 2.5rem 0;
		color: var(--text-secondary);
		font-style: italic;
		font-size: 1.05em;
		background: rgba(59,130,246,0.05);
		border-radius: 0 8px 8px 0;
	}
	/* Images */
	.prose :global(img) {
		width: 100%;
		border-radius: 12px;
		margin: 2rem 0;
		border: 1px solid var(--border);
		display: block;
	}
	/* Video / iframe */
	.prose :global(iframe) {
		width: 100%;
		aspect-ratio: 16/9;
		border-radius: 12px;
		border: 1px solid var(--border);
		margin: 2rem 0;
		display: block;
	}
	.prose :global(video) {
		width: 100%;
		border-radius: 12px;
		margin: 2rem 0;
		border: 1px solid var(--border);
		display: block;
	}
	/* Inline code */
	.prose :global(code) {
		font-family: var(--font-mono);
		font-size: 0.85em;
		background: rgba(6,182,212,0.08);
		border: 1px solid rgba(6,182,212,0.2);
		padding: 2px 7px;
		border-radius: 4px;
		color: var(--cyan);
	}
	/* Code blocks — Shiki wraps in <pre><code> */
	.prose :global(pre) {
		border-radius: 12px;
		padding: 1.5rem 1.75rem;
		overflow-x: auto;
		margin: 2rem 0;
		border: 1px solid var(--border);
		font-size: 0.9rem;
		line-height: 1.65;
	}
	.prose :global(pre code) {
		background: none;
		border: none;
		padding: 0;
		color: inherit;
		font-size: inherit;
	}
	.prose :global(hr) { margin: 3.5rem 0; border-color: var(--border); }
	.prose :global(table) {
		width: 100%;
		border-collapse: collapse;
		margin: 2rem 0;
		font-size: 0.95em;
	}
	.prose :global(th), .prose :global(td) {
		padding: 10px 16px;
		border: 1px solid var(--border);
		text-align: left;
	}
	.prose :global(th) { background: var(--surface2); color: var(--text); font-weight: 600; }

	/* Footer nav */
	.post-footer { margin-top: 3rem; }
	.post-footer-line { border-top: 1px solid var(--border); margin-bottom: 24px; }
	.post-footer-nav { display: flex; justify-content: space-between; align-items: center; }
	.back-link {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		font-size: 14px;
		font-weight: 500;
		color: var(--text-secondary);
		transition: color 0.2s;
	}
	.back-link:hover { color: var(--text); }

	@media (max-width: 720px) {
		.post-cover { min-height: 360px; }
		.cover-content { padding: 40px 0 40px; }
		.prose-wrap { padding: 40px 0 32px; }
	}
</style>
