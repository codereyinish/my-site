---
import type { CollectionEntry } from 'astro:content';
import type { MarkdownHeading } from 'astro';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'] & {
	headings?: MarkdownHeading[];
	readTime?: string;
};

const { title, description, pubDate, updatedDate, heroImage, tags, headings = [], readTime } = Astro.props;
const tocHeadings = headings.filter(h => h.depth <= 3);
const imgSeed = title.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
const coverImg = heroImage ?? `https://picsum.photos/seed/${imgSeed}/1600/700`;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} image={coverImg} />
	</head>
	<body>
		<Header />

		<article class="post-article">
			<!-- Hero cover -->
			<div class="post-cover" style={`background-image:url('${coverImg}')`}>
				<div class="cover-overlay"></div>
				<div class="container">
					<div class="cover-content animate-fadeInDown">
						<a href="/blog" class="back-crumb mono">← Writing</a>
						{tags && tags.length > 0 && (
							<div class="cover-tags">
								{tags.map(t => <span class="cover-tag">{t}</span>)}
							</div>
						)}
						<h1 class="post-title">{title}</h1>
						{description && <p class="post-desc">{description}</p>}
						<div class="post-meta mono">
							<span><FormattedDate date={pubDate} /></span>
							{readTime && <span class="meta-sep">·</span>}
							{readTime && <span>{readTime}</span>}
							{updatedDate && (
								<span class="updated-note">Updated: <FormattedDate date={updatedDate} /></span>
							)}
						</div>
					</div>
				</div>
			</div>

			<!-- Prose + TOC -->
			<div class="container">
				<div class="content-layout animate-fadeInUp">
					<div class="prose-wrap">
						<div class="prose">
							<slot />
						</div>
					<div class="post-footer">
						<div class="post-footer-line"></div>
						{tags && tags.length > 0 && (
							<div class="post-footer-tags">
								<span class="tags-label mono">Tags</span>
								<div class="tags-list">
									{tags.map(t => (
										<a href={`/blog?tag=${encodeURIComponent(t)}`} class="footer-tag">{t}</a>
									))}
								</div>
							</div>
						)}
						<!-- Subscribe banner -->
						<div class="subscribe-banner">
							<div class="subscribe-banner-text">
								<p class="subscribe-banner-title">Enjoyed this post?</p>
								<p class="subscribe-banner-sub">Get new essays straight to your inbox. No spam, unsubscribe anytime.</p>
							</div>
							<a href="https://mbista.beehiiv.com/subscribe" target="_blank" rel="noopener" class="subscribe-btn">
								Subscribe
								<svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
							</a>
						</div>

						<div class="post-footer-nav">
							<a href="/blog" class="back-link">
								<svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
								Back to all posts
							</a>
						</div>
					</div>
				</div>

				<!-- TOC sidebar -->
				{tocHeadings.length > 0 && (
					<aside class="toc-sidebar">
						<div class="toc-inner">
							<p class="toc-label mono">On this page</p>
							<nav class="toc-nav">
								{tocHeadings.map(h => (
									<a
										href={`#${h.slug}`}
										class={`toc-link toc-h${h.depth}`}
										data-heading={h.slug}
									>{h.text}</a>
								))}
							</nav>
						</div>
					</aside>
				)}

				</div>
			</div>
		</article>

		<Footer />

		<!-- Subscribe popup -->
		<div class="sub-popup" id="sub-popup" aria-hidden="true">
			<button class="sub-popup-close" id="sub-popup-close" aria-label="Close">
				<svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 6 6 18M6 6l12 12"/></svg>
			</button>
			<p class="sub-popup-eyebrow mono">Newsletter</p>
			<p class="sub-popup-title">Stay in the loop</p>
			<p class="sub-popup-sub">Get new essays straight to your inbox. No spam, unsubscribe anytime.</p>
			<a href="https://mbista.beehiiv.com/subscribe" target="_blank" rel="noopener" class="sub-popup-btn">
				Subscribe to MB's Writing
				<svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
			</a>
		</div>

		<!-- Code fullscreen modal -->
		<div class="code-modal" id="code-modal">
			<button class="code-modal-close" id="code-modal-close">×</button>
			<pre id="code-modal-pre"></pre>
		</div>

		<!-- Image lightbox -->
		<div class="img-lightbox" id="img-lightbox">
			<button class="img-lightbox-close" id="img-lightbox-close">×</button>
			<img id="img-lightbox-img" src="" alt="" />
		</div>
	</body>
</html>

<style>
	/* Cover */
	.post-cover {
		position: relative;
		min-height: 520px;
		display: flex;
		align-items: flex-end;
		background-size: cover;
		background-position: center;
		background-color: var(--surface);
		/* Gradient fallback when no image */
		background-image: linear-gradient(135deg, #0a0a0a 0%, #111827 50%, #0a0a0a 100%);
		padding-top: 80px;
	}
	.cover-overlay {
		position: absolute;
		inset: 0;
		background: linear-gradient(
			to bottom,
			rgba(0,0,0,0.55) 0%,
			rgba(0,0,0,0.75) 60%,
			rgba(0,0,0,0.97) 100%
		);
	}
	.cover-content {
		position: relative;
		z-index: 2;
		padding: 64px 0 60px;
		max-width: 680px;
	}
	.back-crumb {
		display: inline-block;
		font-size: 11px;
		letter-spacing: 1.5px;
		text-transform: uppercase;
		color: rgba(255,255,255,0.45);
		margin-bottom: 16px;
		transition: color 0.2s;
	}
	.back-crumb:hover { color: rgba(255,255,255,0.7); }
	.cover-tags {
		display: flex;
		gap: 6px;
		flex-wrap: wrap;
		margin-bottom: 14px;
	}
	.cover-tag {
		font-family: var(--font-mono);
		font-size: 10px;
		letter-spacing: 1px;
		text-transform: uppercase;
		padding: 3px 10px;
		border: 1px solid rgba(255,255,255,0.2);
		border-radius: 4px;
		color: rgba(255,255,255,0.5);
	}
	.post-title {
		font-size: clamp(2rem, 5vw, 3.5rem);
		font-weight: 800;
		letter-spacing: -1.5px;
		line-height: 1.1;
		color: #fff;
		margin-bottom: 16px;
	}
	.post-desc {
		font-size: 1.1rem;
		color: rgba(255,255,255,0.6);
		max-width: 560px;
		line-height: 1.65;
		margin-bottom: 20px;
	}
	.post-meta {
		display: flex;
		gap: 20px;
		font-size: 11px;
		letter-spacing: 1px;
		color: rgba(255,255,255,0.4);
		text-transform: uppercase;
	}
	.updated-note { color: rgba(255,255,255,0.3); }

	/* Content layout — centered prose + TOC to the right */
	.content-layout {
		display: grid;
		grid-template-columns: 220px minmax(0, 680px) 220px;
		justify-content: center;
		gap: 0 56px;
		align-items: flex-start;
		padding: 72px 0 64px;
	}

	/* Prose */
	.prose-wrap {
		grid-column: 2;
		min-width: 0;
	}
	.prose {
		font-family: 'Georgia', 'Charter', 'Cambria', serif;
		font-size: 1.18rem;
		line-height: 1.95;
		color: var(--text-secondary);
	}
	.prose :global(h1) {
		font-size: 2rem;
		font-weight: 800;
		letter-spacing: -0.5px;
		color: var(--text);
		margin: 3rem 0 1rem;
	}
	.prose :global(h2) {
		font-size: 1.55rem;
		font-weight: 700;
		letter-spacing: -0.4px;
		color: var(--text);
		margin: 3rem 0 0.85rem;
		padding-bottom: 0.5rem;
		border-bottom: 1px solid var(--border);
	}
	.prose :global(h3) {
		font-size: 1.2rem;
		font-weight: 600;
		color: var(--text);
		margin: 2.25rem 0 0.6rem;
	}
	.prose :global(p) { margin-bottom: 1.75em; }
	.prose :global(a) {
		color: var(--blue);
		border-bottom: 1px solid rgba(59,130,246,0.3);
		transition: border-color 0.2s;
	}
	.prose :global(a:hover) { border-color: var(--blue); opacity: 0.85; }
	.prose :global(ul), .prose :global(ol) { padding-left: 1.75rem; margin-bottom: 1.75em; }
	.prose :global(li) { margin-bottom: 0.5em; line-height: 1.75; }
	.prose :global(blockquote) {
		border-left: 3px solid var(--blue);
		padding: 1rem 1.5rem;
		margin: 2.5rem 0;
		color: var(--text-muted);
		font-style: italic;
		font-size: 1.05em;
		background: var(--surface);
		border-radius: 0 8px 8px 0;
	}
	/* Images */
	.prose :global(img) {
		width: 100%;
		border-radius: 12px;
		margin: 2rem 0;
		border: 1px solid var(--border);
		display: block;
	}
	/* Video / iframe */
	.prose :global(iframe) {
		width: 100%;
		aspect-ratio: 16/9;
		border-radius: 12px;
		border: 1px solid var(--border);
		margin: 2rem 0;
		display: block;
	}
	.prose :global(video) {
		width: 100%;
		border-radius: 12px;
		margin: 2rem 0;
		border: 1px solid var(--border);
		display: block;
	}
	/* Inline code */
	.prose :global(code) {
		font-family: var(--font-mono);
		font-size: 0.85em;
		background: rgba(6,182,212,0.08);
		border: 1px solid rgba(6,182,212,0.2);
		padding: 2px 7px;
		border-radius: 4px;
		color: var(--cyan);
	}
	/* Code blocks — Shiki wraps in <pre><code> */
	.prose :global(pre) {
		border-radius: 12px;
		padding: 1.5rem 1.75rem;
		overflow-x: auto;
		margin: 2rem 0;
		border: 1px solid var(--border);
		font-size: 0.9rem;
		line-height: 1.65;
		background: #000 !important;
	}
	.prose :global(pre code) {
		background: none;
		border: none;
		padding: 0;
		color: inherit;
		font-size: inherit;
	}
	.prose :global(hr) { margin: 3.5rem 0; border-color: var(--border); }
	.prose :global(table) {
		width: 100%;
		border-collapse: collapse;
		margin: 2rem 0;
		font-size: 0.95em;
	}
	.prose :global(th), .prose :global(td) {
		padding: 10px 16px;
		border: 1px solid var(--border);
		text-align: left;
	}
	.prose :global(th) { background: var(--surface2); color: var(--text); font-weight: 600; }

	/* Footer nav */
	.post-footer { margin-top: 3rem; }
	.post-footer-line { border-top: 1px solid var(--border); margin-bottom: 24px; }
	.post-footer-tags {
		display: flex;
		align-items: center;
		gap: 12px;
		margin-bottom: 24px;
		flex-wrap: wrap;
	}
	.tags-label {
		font-size: 11px;
		letter-spacing: 1.5px;
		text-transform: uppercase;
		color: var(--text-muted);
	}
	.tags-list { display: flex; gap: 8px; flex-wrap: wrap; }
	.footer-tag {
		font-family: var(--font-mono);
		font-size: 11px;
		letter-spacing: 0.5px;
		text-transform: uppercase;
		padding: 4px 12px;
		border: 1px solid var(--border);
		border-radius: 100px;
		color: var(--text-secondary);
		transition: border-color 0.2s, color 0.2s;
	}
	.footer-tag:hover { border-color: var(--border-light); color: var(--text); }
	.post-footer-nav { display: flex; justify-content: space-between; align-items: center; }
	.back-link {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		font-size: 14px;
		font-weight: 500;
		color: var(--text-secondary);
		transition: color 0.2s;
	}
	.back-link:hover { color: var(--text); }

	/* TOC sidebar */
	.toc-sidebar {
		grid-column: 1;
		grid-row: 1;
		min-width: 0;
	}
	.toc-inner {
		position: sticky;
		top: 88px;
	}
	.toc-label {
		font-family: var(--font-sans);
		font-size: 11px;
		font-weight: 600;
		letter-spacing: 1.5px;
		text-transform: uppercase;
		color: var(--text-muted);
		margin-bottom: 14px;
	}
	.toc-nav {
		display: flex;
		flex-direction: column;
		gap: 1px;
	}
	.toc-link {
		font-family: var(--font-sans);
		font-size: 13px;
		font-weight: 400;
		line-height: 1.55;
		color: var(--text-muted);
		padding: 5px 0 5px 12px;
		border-left: 2px solid var(--border);
		transition: color 0.15s, border-color 0.15s;
		text-decoration: none;
		display: block;
	}
	.toc-link:hover { color: var(--text-secondary); border-left-color: var(--border-light); }
	.toc-link.active {
		color: var(--text);
		border-left-color: var(--blue);
		font-weight: 500;
	}
	.toc-h2 { padding-left: 12px; }
	.toc-h3 { padding-left: 24px; font-size: 12.5px; color: var(--text-muted); }

	@media (max-width: 1100px) {
		.toc-sidebar { display: none; }
		.content-layout { grid-template-columns: minmax(0, 680px); justify-content: center; }
		.prose-wrap { grid-column: 1; }
	}
	@media (max-width: 720px) {
		.post-cover { min-height: 360px; }
		.cover-content { padding: 40px 0 40px; }
		.content-layout { padding: 40px 0 32px; grid-template-columns: 1fr; }
	}

	/* Subscribe banner (inline at end of post) */
	.subscribe-banner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 24px;
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: 16px;
		padding: 28px 32px;
		margin: 48px 0 32px;
	}
	.subscribe-banner-title {
		font-size: 1rem;
		font-weight: 700;
		color: var(--text);
		margin-bottom: 4px;
	}
	.subscribe-banner-sub {
		font-size: 13px;
		color: var(--text-muted);
		margin: 0;
		line-height: 1.5;
	}
	.subscribe-btn {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		padding: 10px 22px;
		background: var(--text);
		color: var(--bg);
		border-radius: 8px;
		font-size: 13px;
		font-weight: 600;
		white-space: nowrap;
		flex-shrink: 0;
		transition: opacity 0.2s;
	}
	.subscribe-btn:hover { opacity: 0.85; }
	@media (max-width: 600px) {
		.subscribe-banner { flex-direction: column; align-items: flex-start; }
	}

	/* Subscribe popup */
	.sub-popup {
		position: fixed;
		bottom: 32px;
		right: 32px;
		width: 300px;
		background: var(--surface2);
		border: 1px solid var(--border-light);
		border-radius: 16px;
		padding: 28px 28px 24px;
		z-index: 200;
		box-shadow: 0 20px 60px rgba(0,0,0,0.6);
		transform: translateY(20px);
		opacity: 0;
		pointer-events: none;
		transition: opacity 0.35s ease, transform 0.35s ease;
	}
	.sub-popup.visible {
		opacity: 1;
		transform: translateY(0);
		pointer-events: auto;
	}
	.sub-popup-close {
		position: absolute;
		top: 14px;
		right: 14px;
		background: none;
		border: none;
		color: var(--text-muted);
		cursor: pointer;
		padding: 4px;
		line-height: 1;
		transition: color 0.2s;
	}
	.sub-popup-close:hover { color: var(--text); }
	.sub-popup-eyebrow {
		font-size: 10px;
		letter-spacing: 2px;
		text-transform: uppercase;
		color: var(--blue);
		margin-bottom: 8px;
	}
	.sub-popup-title {
		font-size: 1.1rem;
		font-weight: 700;
		color: var(--text);
		margin-bottom: 8px;
		letter-spacing: -0.3px;
	}
	.sub-popup-sub {
		font-size: 13px;
		color: var(--text-muted);
		line-height: 1.55;
		margin-bottom: 20px;
	}
	.sub-popup-btn {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 8px;
		width: 100%;
		padding: 11px 0;
		background: var(--text);
		color: var(--bg);
		border-radius: 8px;
		font-size: 13px;
		font-weight: 600;
		transition: opacity 0.2s;
	}
	.sub-popup-btn:hover { opacity: 0.85; }
	@media (max-width: 480px) {
		.sub-popup { bottom: 16px; right: 16px; left: 16px; width: auto; }
	}


	/* Code fullscreen modal */
	.code-modal {
		display: none;
		position: fixed;
		inset: 0;
		z-index: 300;
		background: rgba(0,0,0,0.92);
		backdrop-filter: blur(8px);
		padding: 48px 32px 32px;
		overflow: auto;
	}
	.code-modal.open { display: block; }
	.code-modal-close {
		position: fixed;
		top: 16px;
		right: 20px;
		background: none;
		border: none;
		color: rgba(255,255,255,0.5);
		font-size: 28px;
		cursor: pointer;
		line-height: 1;
		transition: color 0.2s;
	}
	.code-modal-close:hover { color: #fff; }
	.code-modal pre {
		max-width: 1100px;
		margin: 0 auto;
		background: #000 !important;
		border-radius: 12px;
		padding: 2rem;
		border: 1px solid var(--border);
		font-size: 0.95rem;
		line-height: 1.7;
	}

	/* Image lightbox */
	.img-lightbox {
		display: none;
		position: fixed;
		inset: 0;
		z-index: 300;
		background: rgba(0,0,0,0.92);
		backdrop-filter: blur(8px);
		align-items: center;
		justify-content: center;
		cursor: zoom-out;
		padding: 32px;
	}
	.img-lightbox.open { display: flex; }
	.img-lightbox img {
		max-width: 100%;
		max-height: 90vh;
		border-radius: 8px;
		box-shadow: 0 24px 80px rgba(0,0,0,0.8);
		object-fit: contain;
	}
	.img-lightbox-close {
		position: fixed;
		top: 16px;
		right: 20px;
		background: none;
		border: none;
		color: rgba(255,255,255,0.5);
		font-size: 28px;
		cursor: pointer;
		transition: color 0.2s;
	}
	.img-lightbox-close:hover { color: #fff; }
</style>

<script>
// Highlight the active TOC heading as you scroll
const links = document.querySelectorAll<HTMLAnchorElement>('.toc-link');
if (links.length) {
	const headingEls = Array.from(links).map(l =>
		document.getElementById(l.dataset.heading ?? '')
	).filter(Boolean) as HTMLElement[];

	const observer = new IntersectionObserver(entries => {
		entries.forEach(entry => {
			if (entry.isIntersecting) {
				links.forEach(l => l.classList.remove('active'));
				const active = document.querySelector<HTMLAnchorElement>(
					`.toc-link[data-heading="${entry.target.id}"]`
				);
				active?.classList.add('active');
			}
		});
	}, { rootMargin: '-10% 0px -80% 0px' });

	headingEls.forEach(el => observer.observe(el));
}


</script>

<script>
// Subscribe popup — shows when user scrolls past 80% of article, once per session
const popup = document.getElementById('sub-popup');
const closeBtn = document.getElementById('sub-popup-close');

if (popup && !sessionStorage.getItem('sub-dismissed')) {
	const show = () => {
		popup.classList.add('visible');
		popup.setAttribute('aria-hidden', 'false');
	};

	const dismiss = () => {
		popup.classList.remove('visible');
		popup.setAttribute('aria-hidden', 'true');
		sessionStorage.setItem('sub-dismissed', '1');
	};

	closeBtn?.addEventListener('click', dismiss);

	// Show after scrolling 80% through the article
	const article = document.querySelector('.post-article') as HTMLElement;
	const onScroll = () => {
		if (!article) return;
		const { top, height } = article.getBoundingClientRect();
		const scrolled = (window.innerHeight - top) / height;
		if (scrolled > 0.8) {
			show();
			window.removeEventListener('scroll', onScroll);
		}
	};
	window.addEventListener('scroll', onScroll, { passive: true });
}
</script>

<script>
// ── Code blocks: copy + expand ──────────────────────────────
const codeModal = document.getElementById('code-modal') as HTMLElement;
const codeModalPre = document.getElementById('code-modal-pre') as HTMLElement;
document.getElementById('code-modal-close')?.addEventListener('click', () => codeModal.classList.remove('open'));
codeModal?.addEventListener('click', (e) => { if (e.target === codeModal) codeModal.classList.remove('open'); });

document.querySelectorAll<HTMLElement>('.prose pre').forEach(pre => {
	// Wrap in relative container
	const wrap = document.createElement('div');
	wrap.className = 'code-block-wrap';
	pre.parentNode!.insertBefore(wrap, pre);
	wrap.appendChild(pre);

	// Actions bar
	const actions = document.createElement('div');
	actions.className = 'code-actions';

	// Copy button
	const copyBtn = document.createElement('button');
	copyBtn.className = 'code-btn';
	copyBtn.innerHTML = `<svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg> Copy`;
	copyBtn.addEventListener('click', async () => {
		const code = pre.querySelector('code')?.innerText ?? pre.innerText;
		await navigator.clipboard.writeText(code);
		copyBtn.textContent = 'Copied!';
		copyBtn.classList.add('copied');
		setTimeout(() => { copyBtn.innerHTML = `<svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg> Copy`; copyBtn.classList.remove('copied'); }, 2000);
	});

	// Expand button
	const expandBtn = document.createElement('button');
	expandBtn.className = 'code-btn';
	expandBtn.innerHTML = `<svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/></svg> Expand`;
	expandBtn.addEventListener('click', () => {
		codeModalPre.innerHTML = pre.innerHTML;
		codeModal.classList.add('open');
	});

	actions.appendChild(copyBtn);
	actions.appendChild(expandBtn);
	wrap.appendChild(actions);
});

// Close code modal on Escape
document.addEventListener('keydown', (e) => {
	if (e.key === 'Escape') {
		codeModal?.classList.remove('open');
		imgLightbox?.classList.remove('open');
	}
});

// ── Image lightbox ───────────────────────────────────────────
const imgLightbox = document.getElementById('img-lightbox') as HTMLElement;
const imgLightboxImg = document.getElementById('img-lightbox-img') as HTMLImageElement;
document.getElementById('img-lightbox-close')?.addEventListener('click', () => imgLightbox.classList.remove('open'));
imgLightbox?.addEventListener('click', (e) => { if (e.target === imgLightbox) imgLightbox.classList.remove('open'); });

document.querySelectorAll<HTMLImageElement>('.prose img').forEach(img => {
	const wrap = document.createElement('span');
	wrap.className = 'img-wrap';
	img.parentNode!.insertBefore(wrap, img);
	wrap.appendChild(img);
	wrap.addEventListener('click', () => {
		imgLightboxImg.src = img.src;
		imgLightboxImg.alt = img.alt;
		imgLightbox.classList.add('open');
	});
});
</script>

<style is:global>
